<% content_for :title, "Messages" %>

<section class="page-header">
  <h1>Messages</h1>
  <%= link_to "New message", new_message_path, class: "button" %>
</section>

<div id="messages">
  <% @messages.each do |message| %>
    <article>
      <%= render message %>
      <p><%= link_to "Show details", message %></p>
    </article>
  <% end %>
</div>
