<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "College Network" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>

  <body>
    <header class="topbar">
      <%= link_to "College Network", posts_path, class: "brand brand--glitch", data: { text: "College Network" } %>

      <nav class="topbar__nav" aria-label="Primary">
        <%= link_to "Posts", posts_path %>
        <%= link_to "Profiles", profiles_path %>
        <%= link_to "Messages", messages_path %>
      </nav>

      <div class="topbar__auth">
        <% if user_signed_in? %>
          <span class="topbar__user"><%= current_user.email %></span>
          <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "button button--ghost" %>
        <% else %>
          <%= link_to "Log in", new_user_session_path, class: "button button--ghost" %>
          <%= link_to "Sign up", new_user_registration_path, class: "button" %>
        <% end %>
      </div>
    </header>

    <main class="app-shell">
      <% flash.each do |type, message| %>
        <p class="flash flash--<%= type %>"><%= message %></p>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
